    \"<span class=sf-dump-key>id</span>\" => <span class=sf-dump-num>1</span>
    \"<span class=sf-dump-key>title</span>\" => \"<span class=sf-dump-str title=\"31 characters\">Motor Vehicle Clearing Services</span>\"
    \"<span class=sf-dump-key>slug</span>\" => \"<span class=sf-dump-str title=\"22 characters\">motor-vehicle-clearing</span>\"
    \"<span class=sf-dump-key>short_description</span>\" => \"<span class=sf-dump-str title=\"170 characters\">Professional motor vehicle clearing services at Dar es Salaam Port. We handle passenger vehicles, trucks, buses and commercial vehicles with efficient customs processing.</span>\"
    \"<span class=sf-dump-key>description</span>\" => \"\"\"
      <span class=sf-dump-str title=\"3252 characters\">&lt;div class=&quot;service-content&quot;&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;h2&gt;Motor Vehicle Clearing Services&lt;/h2&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;NEW HEROES INTERNATIONAL LIMITED provides professional motor vehicle clearing services in Tanzania, ensuring that imported vehicles are processed quickly and in full compliance with customs regulations. With extensive experience in port operations and customs documentation, our team ensures smooth clearance of vehicles from the port to the final destination.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;We assist individuals, vehicle dealers, and businesses importing vehicles through Dar es Salaam Port by managing the entire clearing process efficiently.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;Our team handles the documentation, customs procedures, cargo verification, and release coordination to ensure that vehicles are cleared without unnecessary delays.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;h3&gt;Types of Vehicles We Clear&lt;/h3&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;We specialize in clearing different types of vehicles including:&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;ul&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Passenger vehicles&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Commercial vehicles&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Trucks and trailers&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Buses&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Specialized vehicles&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Fleet vehicles&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Utility vehicles&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;/ul&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;Whether you are importing a single vehicle or multiple vehicles for business purposes, our experienced team ensures professional handling of every shipment.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;h3&gt;Our Vehicle Clearing Process&lt;/h3&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;Our vehicle clearing services follow a structured process to ensure efficient results.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;ul&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Verification of shipping documents&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Customs declaration and duty assessment coordination&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Inspection coordination with relevant authorities&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Processing of customs documentation&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Cargo release from port&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Vehicle dispatch and delivery coordination&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;/ul&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;This structured process ensures that vehicles are cleared efficiently and delivered safely.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;h3&gt;Why Choose Our Vehicle Clearing Services&lt;/h3&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;ul&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Experienced clearing professionals&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Fast and efficient processing&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Compliance with customs regulations&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Transparent communication with clients&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                        &lt;li&gt;Reliable cargo handling&lt;/li&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;/ul&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    <span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;h3&gt;Request Vehicle Clearing Assistance&lt;/h3&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                    &lt;p&gt;If you are importing a vehicle into Tanzania and require professional clearing services, contact NEW HEROES INTERNATIONAL LIMITED for reliable assistance.&lt;/p&gt;<span class=\"sf-dump-default sf-dump-ns\">\\n</span></span>
      <span class=sf-dump-str title=\"3252 characters\">                &lt;/div&gt;</span>
